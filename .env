# 服务基础配置
SERVER_PORT=3000
NODE_ENV=development

# MySQL 数据库配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=你的MySQL密码
DB_NAME=video_flow
DB_CONN_LIMIT=10

# Redis 配置
REDIS_URL=redis://127.0.0.1:6379

# 消息队列选型：填 rabbitmq 或 kafka
MQ_TYPE=rabbitmq
# RabbitMQ 配置
MQ_URL=amqp://guest:guest@127.0.0.1:5672
MQ_QUEUE=video_behavior_queue
# Kafka 配置
KAFKA_BROKERS=127.0.0.1:9092
KAFKA_CLIENT_ID=video-recommend-engine
KAFKA_TOPIC=video_behavior_events

# 管理员鉴权 Token
ADMIN_TOKEN=Bearer super_admin_secret_2026

# 打分模型基准权重
ALPHA_WEIGHT=0.5
BETA_WEIGHT=0.2
GAMMA_WEIGHT=0.15
DELTA_WEIGHT=0.15
LAMBDA=0.00005

# 限流规则
WATCH_WINDOW=60000
WATCH_LIMIT=50
REPORT_WINDOW=3600000
REPORT_LIMIT=10

# 定时任务 Cron 表达式
SCORE_CRON=*/15 * * * *
GC_CRON=0 3 * * *